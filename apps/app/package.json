{
  "name": "app",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo start --android --port 8083",
    "ios": "expo start --ios --port 8083",
    "lint": "expo lint",
    "prebuild:android": "expo prebuild --platform android",
    "prebuild:android:clean": "expo prebuild --platform android --clean",
    "prebuild:ios": "expo prebuild --platform ios",
    "prebuild:ios:clean": "expo prebuild --platform ios --clean",
    "reset-project": "node ./scripts/reset-project.js",
    "run:android": "expo run:android --port 8083",
    "run:ios": "expo run:ios --port 8083",
    "start": "expo start --port 8083",
    "typecheck": "tsc --noEmit",
    "web": "expo start --web --port 8083"
  },
  "dependencies": {
    "@expo/vector-icons": "catalog:native",
    "@react-navigation/bottom-tabs": "catalog:native",
    "@react-navigation/elements": "catalog:native",
    "@react-navigation/native": "catalog:native",
    "expo": "catalog:native",
    "expo-constants": "catalog:native",
    "expo-font": "catalog:native",
    "expo-haptics": "catalog:native",
    "expo-image": "catalog:native",
    "expo-linking": "catalog:native",
    "expo-router": "catalog:native",
    "expo-splash-screen": "catalog:native",
    "expo-status-bar": "catalog:native",
    "expo-symbols": "catalog:native",
    "expo-system-ui": "catalog:native",
    "expo-web-browser": "catalog:native",
    "react": "catalog:core",
    "react-dom": "catalog:core",
    "react-native": "catalog:native",
    "react-native-gesture-handler": "catalog:native",
    "react-native-reanimated": "catalog:native",
    "react-native-safe-area-context": "catalog:native",
    "react-native-screens": "catalog:native",
    "react-native-web": "catalog:native",
    "react-native-worklets": "catalog:native"
  },
  "devDependencies": {
    "@types/react": "catalog:dev",
    "eslint": "catalog:dev",
    "eslint-config-expo": "catalog:native",
    "typescript": "catalog:core"
  }
}
