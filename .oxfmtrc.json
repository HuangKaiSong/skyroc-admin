{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "none",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "jsdoc": true,
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "singleAttributePerLine": false,
  "sortImports": {
    "partitionByNewline": true,
    "newlinesBetween": false
  },
  "sortPackageJson": true,
  "ignorePatterns": [
    "node_modules",
    "dist",
    "dist-ssr",
    ".turbo",
    ".next",
    ".cache",
    "coverage",
    "*.local",
    ".claude",
    ".agents",
    "pnpm-lock.yaml",
    "routeTree.gen.ts"
  ]
}