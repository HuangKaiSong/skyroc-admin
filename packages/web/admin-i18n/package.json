{
  "name": "@skyroc/web-admin-i18n",
  "version": "1.0.0",
  "type": "module",
  "description": "Admin web internationalization runtime and language UI.",
  "keywords": [
    "admin",
    "admin-i18n",
    "web-admin-i18n",
    "i18n",
    "i18next",
    "internationalization",
    "jotai"
  ],
  "license": "MIT",
  "author": "",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./src/*"
      ]
    }
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint --fix",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "devDependencies": {
    "@skyroc/core-state": "workspace:*",
    "@skyroc/tsconfig": "workspace:*",
    "@skyroc/types": "workspace:*",
    "@skyroc/web-ui-antd": "workspace:*",
    "@types/react": "catalog:dev",
    "antd": "catalog:web",
    "i18next": "catalog:i18n",
    "jotai": "catalog:core",
    "oxlint": "catalog:dev",
    "react": "catalog:core",
    "react-i18next": "catalog:i18n",
    "rimraf": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:core"
  },
  "peerDependencies": {
    "@skyroc/core-state": ">=1.0.0",
    "@skyroc/web-ui-antd": ">=0.1.0",
    "antd": ">=6.0.0",
    "i18next": ">=25.0.0",
    "jotai": ">=2.0.0",
    "react": ">=18.0.0",
    "react-i18next": ">=16.0.0"
  }
}
