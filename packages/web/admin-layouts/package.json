{
  "name": "@skyroc/web-admin-layouts",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Reusable React admin layout shell for Skyroc admin applications.",
  "keywords": [
    "admin",
    "admin-layout",
    "antd",
    "layout",
    "react",
    "skyroc",
    "tabs"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Ohh-889/skyroc-admin/tree/master/packages/web/admin-layouts",
  "bugs": {
    "url": "https://github.com/Ohh-889/skyroc-admin/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ohh-889/skyroc-admin.git",
    "directory": "packages/web/admin-layouts"
  },
  "author": {
    "name": "Ohh",
    "email": "1509326266@qq.com",
    "url": "https://github.com/Ohh-889"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./src/*"
      ]
    }
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@better-scroll/core": "catalog:web",
    "@skyroc/color": "workspace:*",
    "@skyroc/core-state": "workspace:*",
    "@skyroc/hooks": "workspace:*",
    "@skyroc/web-admin-i18n": "workspace:*",
    "@skyroc/materials": "workspace:*",
    "@skyroc/utils": "workspace:*",
    "@skyroc/web-admin-theme": "workspace:*",
    "@skyroc/web-ui": "workspace:*",
    "@skyroc/web-ui-antd": "workspace:*",
    "@skyroc/web-ui-compose": "workspace:*",
    "ahooks": "catalog:utils",
    "clsx": "catalog:utils",
    "defu": "catalog:utils",
    "jotai": "catalog:core"
  },
  "peerDependencies": {
    "@tanstack/react-router": "^1.140.0",
    "antd": ">=6.0.0",
    "i18next": "^25.0.0",
    "motion": "^12.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-i18next": "^16.0.0"
  },
  "devDependencies": {
    "@skyroc/config": "workspace:*",
    "@skyroc/tsconfig": "workspace:*",
    "@skyroc/types": "workspace:*",
    "@tanstack/react-router": "catalog:web",
    "@testing-library/jest-dom": "catalog:dev",
    "@testing-library/react": "catalog:dev",
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "antd": "catalog:web",
    "i18next": "catalog:i18n",
    "jsdom": "catalog:dev",
    "motion": "catalog:ui-shared",
    "oxlint": "catalog:dev",
    "react": "catalog:core",
    "react-dom": "catalog:core",
    "react-i18next": "catalog:i18n",
    "rimraf": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:core",
    "vitest": "catalog:dev"
  }
}
