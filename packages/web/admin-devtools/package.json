{
  "name": "@skyroc/web-admin-devtools",
  "version": "0.1.0",
  "type": "module",
  "description": "Configurable development-only admin devtools panels for Skyroc admin applications.",
  "keywords": [
    "admin",
    "devtools",
    "jotai",
    "query",
    "react",
    "router",
    "skyroc",
    "tanstack"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Ohh-889/skyroc-admin/tree/master/packages/web/admin-devtools",
  "bugs": {
    "url": "https://github.com/Ohh-889/skyroc-admin/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ohh-889/skyroc-admin.git",
    "directory": "packages/web/admin-devtools"
  },
  "author": {
    "name": "Ohh",
    "email": "1509326266@qq.com",
    "url": "https://github.com/Ohh-889"
  },
  "sideEffects": [
    "./dist/jotai.js",
    "./src/jotai.ts",
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./src/*"
      ]
    }
  },
  "exports": {
    ".": "./src/index.ts",
    "./jotai": "./src/jotai.ts"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      },
      "./jotai": {
        "import": {
          "types": "./dist/jotai.d.ts",
          "default": "./dist/jotai.js"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint --fix",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@tanstack/react-devtools": "catalog:web",
    "@tanstack/react-query-devtools": "catalog:web",
    "@tanstack/react-router-devtools": "catalog:web",
    "jotai-devtools": "catalog:web"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-router": "^1.140.0",
    "jotai": ">=2.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@skyroc/config": "workspace:*",
    "@skyroc/tsconfig": "workspace:*",
    "@skyroc/types": "workspace:*",
    "@tanstack/react-query": "catalog:core",
    "@tanstack/react-router": "catalog:web",
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "jotai": "catalog:core",
    "oxlint": "catalog:dev",
    "react": "catalog:core",
    "react-dom": "catalog:core",
    "rimraf": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:core"
  }
}
