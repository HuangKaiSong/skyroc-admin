{
  "name": "@skyroc/materials",
  "version": "2.5.0",
  "private": false,
  "type": "module",
  "description": "React admin layout materials for Skyroc - slot-based AdminLayout and multi-style PageTab components",
  "keywords": [
    "admin-layout",
    "layout",
    "materials",
    "page-tabs",
    "react",
    "skyroc",
    "soybean-admin",
    "tabs",
    "typescript",
    "ui"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Ohh-889/skyroc-admin/tree/master/packages/web/materials",
  "bugs": {
    "url": "https://github.com/Ohh-889/skyroc-admin/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ohh-889/skyroc-admin.git",
    "directory": "packages/web/materials"
  },
  "author": {
    "name": "Ohh",
    "email": "1509326266@qq.com",
    "url": "https://github.com/Ohh-889"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./src/*"
      ]
    }
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@skyroc/color": "workspace:*",
    "@skyroc/web-ui": "workspace:*",
    "@skyroc/utils": "workspace:*",
    "clsx": "catalog:utils"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@skyroc/config": "workspace:*",
    "@skyroc/tsconfig": "workspace:*",
    "@testing-library/jest-dom": "catalog:dev",
    "@testing-library/react": "catalog:dev",
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "oxlint": "catalog:dev",
    "react": "catalog:core",
    "react-dom": "catalog:core",
    "rimraf": "catalog:dev",
    "tsdown": "catalog:dev",
    "typed-css-modules": "0.9.1",
    "typescript": "catalog:core"
  }
}
