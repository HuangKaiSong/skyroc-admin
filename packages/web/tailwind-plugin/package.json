{
  "name": "@skyroc/tailwind-plugin",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "description": "Tailwind CSS plugin for Skyroc UI — OKLCH theme tokens, feedback colors, sidebar palette, and design-system presets",
  "keywords": [
    "design-system",
    "oklch",
    "skyroc",
    "tailwind",
    "tailwind-plugin",
    "tailwindcss",
    "theme",
    "ui-tokens"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Ohh-889/skyroc-admin/tree/master/packages/web/tailwind-plugin",
  "bugs": {
    "url": "https://github.com/Ohh-889/skyroc-admin/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ohh-889/skyroc-admin.git",
    "directory": "packages/web/tailwind-plugin"
  },
  "author": {
    "name": "Ohh",
    "email": "1509326266@qq.com",
    "url": "https://github.com/Ohh-889"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./src/*"
      ]
    }
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@skyroc/color": "workspace:*",
    "@skyroc/ui-tokens": "workspace:*",
    "@unocss/core": "catalog:dev",
    "tailwindcss": "catalog:css"
  },
  "devDependencies": {
    "@skyroc/config": "workspace:*",
    "@skyroc/tsconfig": "workspace:*",
    "oxlint": "catalog:dev",
    "rimraf": "catalog:dev",
    "tsdown": "catalog:dev"
  }
}
