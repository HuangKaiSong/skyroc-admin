{
  "name": "@skyroc/web-admin-notification",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Reusable admin notification provider, hooks, and header action for Skyroc admin applications.",
  "keywords": [
    "admin",
    "antd",
    "notification",
    "react",
    "skyroc"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Ohh-889/skyroc-admin/tree/master/packages/web/admin-notification",
  "bugs": {
    "url": "https://github.com/Ohh-889/skyroc-admin/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ohh-889/skyroc-admin.git",
    "directory": "packages/web/admin-notification"
  },
  "author": {
    "name": "Ohh",
    "email": "1509326266@qq.com",
    "url": "https://github.com/Ohh-889"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./src/*"
      ]
    }
  },
  "exports": {
    ".": "./src/index.ts",
    "./mock": "./src/mock.ts"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      },
      "./mock": {
        "import": {
          "types": "./dist/mock.d.ts",
          "default": "./dist/mock.js"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint --fix",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@skyroc/web-ui-antd": "workspace:*",
    "@skyroc/web-ui-compose": "workspace:*",
    "clsx": "catalog:utils",
    "dayjs": "catalog:utils",
    "nanoid": "catalog:utils"
  },
  "peerDependencies": {
    "antd": ">=6.0.0",
    "i18next": "^25.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-i18next": "^16.0.0"
  },
  "devDependencies": {
    "@skyroc/config": "workspace:*",
    "@skyroc/tsconfig": "workspace:*",
    "@skyroc/types": "workspace:*",
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "antd": "catalog:web",
    "i18next": "catalog:i18n",
    "oxlint": "catalog:dev",
    "react": "catalog:core",
    "react-dom": "catalog:core",
    "react-i18next": "catalog:i18n",
    "rimraf": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:core"
  }
}
