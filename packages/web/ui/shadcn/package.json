{
  "name": "@skyroc/web-ui",
  "version": "0.1.0",
  "private": false,
  "description": "A modern React UI component library for SoybeanAdmin",
  "keywords": [
    "antd",
    "component-library",
    "components",
    "design-system",
    "react",
    "soybean-admin",
    "typescript",
    "ui"
  ],
  "homepage": "https://github.com/soybeanjs/soybean-admin-react/tree/main/packages/ui/primitives",
  "bugs": {
    "url": "https://github.com/soybeanjs/soybean-admin-react/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Soybean Admin Team",
    "url": "https://github.com/soybeanjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/soybeanjs/soybean-admin-react.git",
    "directory": "packages/ui/primitives"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint --fix",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "catalog:ui-shared",
    "@radix-ui/react-tooltip": "catalog:ui-shared",
    "@skyroc/color": "workspace:*",
    "@skyroc/ui-types": "workspace:*",
    "@skyroc/utils": "workspace:*",
    "react": "catalog:core",
    "react-dom": "catalog:core",
    "tailwind-variants": "catalog:utils"
  },
  "devDependencies": {
    "@soybeanjs/eslint-config": "catalog:dev",
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "oxlint": "catalog:dev"
  }
}
