{
  "name": "@skyroc/native-theme",
  "version": "0.1.0",
  "private": false,
  "description": "Design tokens and NativeWind preset for React Native components",
  "license": "MIT",
  "files": [
    "dist",
    "tailwind.config.ts"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./preset": {
      "import": {
        "types": "./dist/presets/nativewind-preset.d.ts",
        "default": "./dist/presets/nativewind-preset.js"
      }
    },
    "./tailwind": "./tailwind.config.ts"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@skyroc/color": "workspace:*",
    "@skyroc/ui-tokens": "workspace:*",
    "@skyroc/ui-types": "workspace:*"
  },
  "devDependencies": {
    "@skyroc/tsconfig": "workspace:*",
    "typescript": "catalog:core"
  },
  "peerDependencies": {
    "nativewind": "^4.1.0",
    "tailwindcss": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "nativewind": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    }
  }
}
